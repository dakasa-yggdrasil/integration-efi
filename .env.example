# EFI/Pix adapter env knobs (production homologation = false uses pix-h URL).

EFI_API_CLIENT_KEY_ID=
EFI_API_CLIENT_SECRET=
EFI_CERTIFICATE=/etc/efi/cert.p12
EFI_CERTIFICATE_BASE64=
EFI_BASE_URL=https://pix.api.efipay.com.br
EFI_MTLS_ENABLED=true
EFI_WEBHOOK_PORT=9079

# Adapter transport (default http; switch to amqp for in-cluster RabbitMQ).
YGGDRASIL_TRANSPORT=http
ADAPTER_PORT=8081
HEALTHCHECK_PORT=8080

# OpenTelemetry (optional).
OTEL_EXPORTER_OTLP_ENDPOINT=
